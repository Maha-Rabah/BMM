---
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 3;

// Generate paths dynamically
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  // Group posts by category
  const categories = {};
  for (const post of allPosts) {
    const cat = post.data.category;
    if (!categories[cat]) categories[cat] = [];
    categories[cat].push(post);
  }

  // Build paths for each category page
  const paths = [];
  for (const [category, posts] of Object.entries(categories)) {
    const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
    for (let i = 1; i <= totalPages; i++) {
      paths.push({ params: { category, page: i.toString() } });
    }
  }

  return paths;
}

// Get all posts and current params
const allPosts = await getCollection('posts');
const { category, page } = Astro.params;
const currentPage = parseInt(page);

// Filter posts by category
const categoryPosts = allPosts
  .filter(p => p.data.category === category)
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

// Slice for current page
const start = (currentPage - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const paginated = categoryPosts.slice(start, end);

// Pagination URLs
const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);
const prevPage = currentPage > 1 ? `/category/${category}/${currentPage - 1}` : null;
const nextPage = currentPage < totalPages ? `/category/${category}/${currentPage + 1}` : null;
---

<html>
  <head><title>{category} - Page {currentPage}</title></head>
  <body>
    <h1>Category: {category}</h1>

    <ul>
      {paginated.map(post => (
        <li><a href={`/post/${post.slug}`}>{post.data.title}</a></li>
      ))}
    </ul>

    <nav>
      {prevPage && <a href={prevPage}>Previous</a>}
      {nextPage && <a href={nextPage}>Next</a>}
    </nav>
  </body>
</html>
